<config>
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">
    <banner>
      <motd>
        <banner>Welkom! Dit toestel is geconfigureerd via NETCONF automatisering.</banner>
      </motd>
    </banner>
    <hostname>MyAutoRouter</hostname>
    <username>
      <name>autouser</name>
      <privilege>15</privilege>
      <password>
        <encryption>0</encryption>
        <password>AutoPass123</password>
      </password>
    </username>
    <ip>
      <name-server>
        <no-vrf>8.8.8.8</no-vrf>
      </name-server>
      <route>
        <ip-route-interface-forwarding-list>
          <prefix>172.20.0.0</prefix>
          <mask>255.255.0.0</mask>
          <fwd-list>
            <fwd>10.0.0.254</fwd>
          </fwd-list>
        </ip-route-interface-forwarding-list>
      </route>
      <access-list>
        <extended xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-acl">
          <name>AUTOMATION_ACL</name>
          <access-list-seq-rule>
            <sequence>10</sequence>
            <ace-rule>
              <action>permit</action>
              <protocol>ip</protocol>
              <ipv4-address>10.0.0.0</ipv4-address>
              <mask>0.255.255.255</mask>
              <dst-any/>
            </ace-rule>
          </access-list-seq-rule>
          <access-list-seq-rule>
            <sequence>20</sequence>
            <ace-rule>
              <action>deny</action>
              <protocol>ip</protocol>
              <any/>
              <dst-any/>
            </ace-rule>
          </access-list-seq-rule>
        </extended>
      </access-list>
    </ip>
    <interface>
      <GigabitEthernet>
        <name>1</name>
        <description>Geconfigureerd via NETCONF Automatisering</description>
      </GigabitEthernet>
      <Loopback>
        <name>100</name>
        <description>Auto-Loopback1</description>
        <ip>
          <address>
            <primary>
              <address>10.100.0.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
      </Loopback>
      <Loopback>
        <name>101</name>
        <description>Auto-Loopback2</description>
        <ip>
          <address>
            <primary>
              <address>10.101.0.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
      </Loopback>
      <Loopback>
        <name>102</name>
        <description>Auto-Loopback3-IPv6</description>
        <ipv6>
          <address>
            <prefix-list>
              <prefix>2001:db8:100::1/64</prefix>
            </prefix-list>
          </address>
        </ipv6>
      </Loopback>
    </interface>
    <router>
      <ospf xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-ospf">
        <id>1</id>
        <network>
          <ip>10.100.0.0</ip>
          <mask>0.0.255.255</mask>
          <area>0</area>
        </network>
        <network>
          <ip>10.101.0.0</ip>
          <mask>0.0.255.255</mask>
          <area>0</area>
        </network>
      </ospf>
    </router>
    <snmp-server>
      <community xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-snmp">
        <name>AutoCommunity</name>
      </community>
    </snmp-server>
    <ntp>
      <server xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-ntp">
        <server-list>
          <ip-address>216.239.35.0</ip-address>
        </server-list>
      </server>
    </ntp>
  </native>
</config>
